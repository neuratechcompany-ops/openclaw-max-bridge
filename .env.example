# MAX Messenger Bridge — Environment Variables
# Copy this file to .env and fill in your tokens:
#   cp .env.example .env

MAX_TOKEN=your_max_bot_token_here
OC_TOKEN=your_openclaw_token_here

# Optional: OpenClaw API URL (default: localhost)
# OC_API=http://your-server:18789/v1/chat/completions

# Optional: Proactive HTTP server port (default: 18790)
# PROACTIVE_PORT=18790

# Optional: Model (default: deepseek/deepseek-v4-flash, use deepseek/deepseek-v4-pro for deeper answers)
# OC_MODEL=deepseek/deepseek-v4-flash
